<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.web.WebView?>
<?import javafx.scene.text.Text?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.paperreview.controller.MainController">

    <top>
        <VBox>
            <!-- Custom Title Bar -->
            <HBox style="-fx-background-color: #2c3e50; -fx-padding: 5 10 5 10;" spacing="10" alignment="CENTER_LEFT">
                <Text text="📄 Academic Paper Review Assistant" style="-fx-fill: white; -fx-font-size: 14px; -fx-font-weight: bold;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button fx:id="minimizeButton" text="─" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 16px; -fx-cursor: hand;" onAction="#handleMinimize"/>
                <Button fx:id="maximizeButton" text="□" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 16px; -fx-cursor: hand;" onAction="#handleMaximize"/>
                <Button fx:id="closeButton" text="✕" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 16px; -fx-cursor: hand;" onAction="#handleClose"/>
            </HBox>

            <!-- Menu Bar -->
            <MenuBar>
                <Menu text="File">
                    <MenuItem text="Open PDF" onAction="#handleOpenPDF"/>
                    <SeparatorMenuItem/>
                    <Menu text="Export">
                        <MenuItem text="Export as CSV" onAction="#handleExportCSV"/>
                        <MenuItem text="Export as DOCX" onAction="#handleExportDOCX"/>
                        <MenuItem text="Export as PDF" onAction="#handleExportPDF"/>
                    </Menu>
                    <SeparatorMenuItem/>
                    <MenuItem text="Save Highlighted PDF" onAction="#saveHighlightedPDF"/>
                    <SeparatorMenuItem/>
                    <MenuItem text="Exit" onAction="#handleExit"/>
                </Menu>
                <Menu text="View">
                    <MenuItem text="Toggle Dark Mode" onAction="#handleToggleDarkMode"/>
                    <MenuItem text="Reset View" onAction="#handleResetView"/>
                </Menu>
                <Menu text="Help">
                    <MenuItem text="Documentation" onAction="#handleDocumentation"/>
                    <SeparatorMenuItem/>
                    <MenuItem text="About" onAction="#handleAbout"/>
                </Menu>
            </MenuBar>

            <!-- Tool Bar with Styled Buttons -->
            <ToolBar>
                <Button text="Upload PDF" onAction="#handleOpenPDF"/>
                <Button text="Analyze Paper" onAction="#handleAnalyze"/>
                <Button text="Show Source Lines" onAction="#handleShowSourceLines"/>
                <Separator/>
                <Button text="🔆 Highlight Extracted Info" onAction="#handleHighlightExtractedInfo"/>
                <Button text="📂 Open Highlighted PDF" onAction="#openHighlightedPDF"/>
                <Button text="💾 Save Highlighted PDF" onAction="#saveHighlightedPDF"/>
                <Separator/>
                <Button text="Export Report" onAction="#handleExport"/>
                <Button text="Clear All" onAction="#handleClear"/>
                <Separator/>
                <Label text="Status:"/>
                <Label fx:id="statusLabel" text="Ready"/>
                <ProgressBar fx:id="progressIndicator" visible="false" prefWidth="100"/>
            </ToolBar>
        </VBox>
    </top>

    <center>
        <SplitPane dividerPositions="0.4" BorderPane.alignment="CENTER">
            <items>
                <!-- Left Panel - PDF Viewer -->
                <VBox spacing="10">
                    <padding>
                        <Insets top="10" right="10" bottom="10" left="10"/>
                    </padding>
                    <Label text="PDF Viewer" style="-fx-font-weight: bold; -fx-font-size: 14px; -fx-text-fill: #2c3e50;"/>
                    <WebView fx:id="pdfPreview" VBox.vgrow="ALWAYS" prefHeight="500"/>
                    <Label text="💡 Tip: For better PDF viewing experience, use 'Open Highlighted PDF' button"
                           style="-fx-text-fill: #666; -fx-font-size: 11px;"/>
                </VBox>

                <!-- Right Panel - Tabs -->
                <TabPane tabClosingPolicy="UNAVAILABLE" VBox.vgrow="ALWAYS">

                    <!-- Tab 1: Extracted Information -->
                    <Tab text="📋 Extracted Information">
                        <ScrollPane fitToWidth="true">
                            <VBox spacing="8">
                                <padding><Insets top="10" right="10" bottom="10" left="10"/></padding>

                                <Label text="Basic Information" style="-fx-font-weight: bold; -fx-font-size: 14px; -fx-text-fill: #2c3e50;"/>
                                <Separator/>

                                <Label text="Paper Title" style="-fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                                <Label fx:id="paperTitleLabel" wrapText="true" style="-fx-background-color: #ecf0f1; -fx-padding: 5; -fx-border-radius: 3;"/>

                                <Label text="Authors" style="-fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                                <Label fx:id="authorsLabel" wrapText="true" style="-fx-background-color: #ecf0f1; -fx-padding: 5; -fx-border-radius: 3;"/>

                                <Label text="Abstract" style="-fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                                <TextArea fx:id="abstractLabel" wrapText="true" editable="false" style="-fx-background-color: #ecf0f1;" prefHeight="100"/>

                                <Label text="Keywords" style="-fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                                <Label fx:id="keywordsLabel" wrapText="true" style="-fx-background-color: #ecf0f1; -fx-padding: 5; -fx-border-radius: 3;"/>

                                <Label text="Publication Details" style="-fx-font-weight: bold; -fx-font-size: 14px; -fx-text-fill: #2c3e50;"/>
                                <Separator/>

                                <Label text="Year" style="-fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                                <Label fx:id="yearLabel" wrapText="true" style="-fx-background-color: #ecf0f1; -fx-padding: 5; -fx-border-radius: 3;"/>

                                <Label text="Venue" style="-fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                                <Label fx:id="venueLabel" wrapText="true" style="-fx-background-color: #ecf0f1; -fx-padding: 5; -fx-border-radius: 3;"/>

                                <Label text="DOI" style="-fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                                <Label fx:id="doiLabel" wrapText="true" style="-fx-background-color: #ecf0f1; -fx-padding: 5; -fx-border-radius: 3;"/>

                                <Label text="Research Components" style="-fx-font-weight: bold; -fx-font-size: 14px; -fx-text-fill: #2c3e50;"/>
                                <Separator/>

                                <Label text="Research Domain" style="-fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                                <Label fx:id="domainLabel" wrapText="true" style="-fx-background-color: #ecf0f1; -fx-padding: 5; -fx-border-radius: 3;"/>

                                <Label text="Research Problem" style="-fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                                <TextArea fx:id="problemLabel" wrapText="true" editable="false" style="-fx-background-color: #ecf0f1;" prefHeight="60"/>

                                <Label text="Research Gap" style="-fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                                <TextArea fx:id="gapLabel" wrapText="true" editable="false" style="-fx-background-color: #ecf0f1;" prefHeight="60"/>

                                <Label text="Research Questions" style="-fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                                <Label fx:id="questionsLabel" wrapText="true" style="-fx-background-color: #ecf0f1; -fx-padding: 5; -fx-border-radius: 3;"/>

                                <Label text="Hypothesis" style="-fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                                <Label fx:id="hypothesisLabel" wrapText="true" style="-fx-background-color: #ecf0f1; -fx-padding: 5; -fx-border-radius: 3;"/>

                                <Label text="Methodology" style="-fx-font-weight: bold; -fx-font-size: 14px; -fx-text-fill: #2c3e50;"/>
                                <Separator/>

                                <Label text="Methodology" style="-fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                                <TextArea fx:id="methodologyLabel" wrapText="true" editable="false" style="-fx-background-color: #ecf0f1;" prefHeight="80"/>

                                <Label text="Data Collection" style="-fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                                <Label fx:id="dataCollectionLabel" wrapText="true" style="-fx-background-color: #ecf0f1; -fx-padding: 5; -fx-border-radius: 3;"/>

                                <Label text="Sample Size" style="-fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                                <Label fx:id="sampleSizeLabel" wrapText="true" style="-fx-background-color: #ecf0f1; -fx-padding: 5; -fx-border-radius: 3;"/>

                                <Label text="Tools &amp; Technologies" style="-fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                                <Label fx:id="toolsLabel" wrapText="true" style="-fx-background-color: #ecf0f1; -fx-padding: 5; -fx-border-radius: 3;"/>

                                <Label text="Evaluation Metrics" style="-fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                                <Label fx:id="metricsLabel" wrapText="true" style="-fx-background-color: #ecf0f1; -fx-padding: 5; -fx-border-radius: 3;"/>

                                <Label text="Results &amp; Findings" style="-fx-font-weight: bold; -fx-font-size: 14px; -fx-text-fill: #2c3e50;"/>
                                <Separator/>

                                <Label text="Key Findings" style="-fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                                <TextArea fx:id="findingsLabel" wrapText="true" editable="false" style="-fx-background-color: #ecf0f1;" prefHeight="100"/>

                                <Label text="Models &amp; Algorithms" style="-fx-font-weight: bold; -fx-font-size: 14px; -fx-text-fill: #9C27B0;"/>
                                <Separator/>
                                <Label fx:id="modelsUsedLabel" wrapText="true" style="-fx-background-color: #f3e5f5; -fx-padding: 5; -fx-border-radius: 3;"/>

                                <Label text="Limitations &amp; Future Work" style="-fx-font-weight: bold; -fx-font-size: 14px; -fx-text-fill: #2c3e50;"/>
                                <Separator/>

                                <Label text="Limitations" style="-fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                                <TextArea fx:id="limitationsLabel" wrapText="true" editable="false" style="-fx-background-color: #ecf0f1;" prefHeight="60"/>

                                <Label text="Future Work" style="-fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                                <TextArea fx:id="futureWorkLabel" wrapText="true" editable="false" style="-fx-background-color: #ecf0f1;" prefHeight="60"/>

                                <Label text="Paper Metrics" style="-fx-font-weight: bold; -fx-font-size: 14px; -fx-text-fill: #2c3e50;"/>
                                <Separator/>

                                <Label text="Figures" style="-fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                                <Label fx:id="figuresLabel" wrapText="true" style="-fx-background-color: #ecf0f1; -fx-padding: 5; -fx-border-radius: 3;"/>

                                <Label text="Tables" style="-fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                                <Label fx:id="tablesLabel" wrapText="true" style="-fx-background-color: #ecf0f1; -fx-padding: 5; -fx-border-radius: 3;"/>

                                <Label text="References" style="-fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                                <Label fx:id="referencesLabel" wrapText="true" style="-fx-background-color: #ecf0f1; -fx-padding: 5; -fx-border-radius: 3;"/>

                                <Label text="Citations" style="-fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                                <Label fx:id="citationsLabel" wrapText="true" style="-fx-background-color: #ecf0f1; -fx-padding: 5; -fx-border-radius: 3;"/>

                                <Label text="Publication Category" style="-fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                                <Label fx:id="publicationLabel" wrapText="true" style="-fx-background-color: #ecf0f1; -fx-padding: 5; -fx-border-radius: 3;"/>

                                <Label text="Readability" style="-fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                                <Label fx:id="readabilityLabel" wrapText="true" style="-fx-background-color: #ecf0f1; -fx-padding: 5; -fx-border-radius: 3;"/>
                            </VBox>
                        </ScrollPane>
                    </Tab>

                    <!-- Tab 2: Review Assistant -->
                    <Tab text="⭐ Review Assistant">
                        <ScrollPane fitToWidth="true">
                            <VBox spacing="8">
                                <padding><Insets top="10" right="10" bottom="10" left="10"/></padding>

                                <Label text="Executive Summary" style="-fx-font-weight: bold; -fx-font-size: 14px; -fx-text-fill: #2c3e50;"/>
                                <TextArea fx:id="summaryArea" wrapText="true" prefHeight="120" style="-fx-background-color: #ecf0f1;"/>

                                <Label text="Strengths" style="-fx-font-weight: bold; -fx-font-size: 14px; -fx-text-fill: #27ae60;"/>
                                <ListView fx:id="strengthsList" prefHeight="100"/>

                                <Label text="Weaknesses" style="-fx-font-weight: bold; -fx-font-size: 14px; -fx-text-fill: #e74c3c;"/>
                                <ListView fx:id="weaknessesList" prefHeight="100"/>

                                <Label text="Future Research Scope" style="-fx-font-weight: bold; -fx-font-size: 14px; -fx-text-fill: #3498db;"/>
                                <ListView fx:id="futureScopeList" prefHeight="100"/>

                                <Label text="Quality Assessment" style="-fx-font-weight: bold; -fx-font-size: 14px; -fx-text-fill: #2c3e50;"/>
                                <ProgressBar fx:id="qualityScoreBar" prefWidth="300"/>
                                <Label fx:id="qualityScoreLabel" style="-fx-font-weight: bold;"/>

                                <Label text="Writing Quality" style="-fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                                <Label fx:id="writingQualityLabel" wrapText="true" style="-fx-background-color: #ecf0f1; -fx-padding: 5; -fx-border-radius: 3;"/>

                                <Label text="Plagiarism Risk" style="-fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                                <Label fx:id="plagiarismLabel" wrapText="true" style="-fx-background-color: #ecf0f1; -fx-padding: 5; -fx-border-radius: 3;"/>

                                <Label text="Recommendation" style="-fx-font-weight: bold; -fx-font-size: 14px; -fx-text-fill: #e74c3c;"/>
                                <Label fx:id="recommendationLabel" wrapText="true" style="-fx-background-color: #fdebd0; -fx-padding: 10; -fx-border-radius: 5; -fx-font-weight: bold;"/>
                            </VBox>
                        </ScrollPane>
                    </Tab>
                </TabPane>
            </items>
        </SplitPane>
    </center>
</BorderPane>